{
  "name": "warhammer-api",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "pipeline": "npm run pipeline -w @warhammer-api/pipeline",
    "pipeline:download": "npm run pipeline:download -w @warhammer-api/pipeline",
    "pipeline:convert": "npm run pipeline:convert -w @warhammer-api/pipeline",
    "api:dev": "npm run dev -w @warhammer-api/api",
    "api:deploy": "npm run deploy -w @warhammer-api/api"
  }
}
