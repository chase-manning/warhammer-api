  "abilities": [
    {
      "name": "Infiltrators",
      "description": "INFILTRATORS\n\nMany armies employ reconnaissance units who can sit concealed, waiting for the right moment to strike.\nDuring deployment, if every model in a unit has this ability, then when you set it up, it can be set up anywhere on the battlefield that is more than 9\" horizontally away from the enemy deployment zone and all enemy models.",
      "type": "Core",
      "parameter": null
    },
    {
      "name": "Stealth",
      "description": "STEALTH\n\nSome warriors are masters of disguise and concealment.\nIf every model in a unit has this ability, then each time a ranged attack is made against it, subtract 1 from that attack’s Hit roll.",
      "type": "Core",
      "parameter": null
    },
    {
      "name": "Pech’ra",
      "description": "Ranged weapons equipped by the bearer’s unit have the [IGNORES COVER] ability.",
      "type": "Wargear",
      "parameter": null
    },
    {
      "name": "Bounty Hunters",
      "description": "At the start of the battle, select one unit from your opponent’s army. Each time a model in this unit makes an attack that targets that unit, that attack has the [LETHAL HITS] and [PRECISION] abilities.",
      "type": "Datasheet",
      "parameter": null
    }
  ],
