  "options": [
    {
      "datasheetId": "000004172",
      "line": 1,
      "button": "•",
      "description": "Any number of models can each have their Corsair firearm replaced with one of the following:\n• 1 shardcarbine\n• 1 shuriken catapult\n• 1 spar-glaive"
    },
    {
      "datasheetId": "000004172",
      "line": 2,
      "button": "•",
      "description": "For every 5 models in this unit, 1 model’s Corsair firearm can be replaced with one of the following:\n• 1 Aeldari missile launcher\n• 1 blaster\n• 1 dark lance\n• 1 flamer\n• 1 fusion gun\n• 1 shredder\n• 1 shuriken cannon\n• 1 splinter cannon"
    },
    {
      "datasheetId": "000004172",
      "line": 3,
      "button": "•",
      "description": "The Corsair Skyreaver Felarch can be equipped with one of the following:\n• 1 dissonance pistol\n• 1 void sabre"
    }
