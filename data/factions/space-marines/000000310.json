  "options": [
    {
      "datasheetId": "000000310",
      "line": 1,
      "button": "•",
      "description": "1 Wolf Scout’s boltgun and bolt pistol can be replaced with one of the following:\n• 1 bolt pistol and 1 power weapon\n• 1 plasma pistol and 1 boltgun"
    },
    {
      "datasheetId": "000000310",
      "line": 2,
      "button": "•",
      "description": "1 Wolf Scout’s boltgun can be replaced with one of the following:\n• 1 flamer\n• 1 grav-gun\n• 1 heavy bolter\n• 1 meltagun\n• 1 missile launcher\n• 1 plasma gun"
    },
    {
      "datasheetId": "000000310",
      "line": 3,
      "button": "•",
      "description": "Any number of models can each have their boltgun replaced with one of the following:\n• 1 Astartes shotgun\n• 1 combat knife"
    },
    {
      "datasheetId": "000000310",
      "line": 4,
      "button": "•",
      "description": "The Wolf Scout Pack Leader’s bolt pistol and boltgun can be replaced with with 1 twin lightning claws, or two different weapons from the following list:*\n• 1 bolt pistol\n• 1 boltgun\n• 1 combi-weapon\n• 1 grav-pistol\n• 1 hand flamer\n• 1 inferno pistol\n• 1 plasma pistol\n• 1 storm bolter\n• 1 Astartes chainsword\n• 1 power fist\n• 1 power weapon\n• 1 thunder hammer."
    },
    {
      "datasheetId": "000000310",
      "line": 5,
      "button": "*",
      "description": "* This model can only be equipped with two ranged weapons if one of them is a Pistol (and it can only have one Pistol)"
    }
  ],
