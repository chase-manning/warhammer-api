  "abilities": [
    {
      "name": "Oath of Moment",
      "description": "If your Army Faction is ADEPTUS ASTARTES, at the start of your Command phase, select one unit from your opponent’s army. Until the start of your next Command phase, that enemy unit is your Oath of Moment target. Each time a model with this ability makes an attack that targets your Oath of Moment target:\n\n• You can re-roll the Hit roll.\n• If you are using a Codex: Space Marines Detachment and your army does not include one or more units with the Black Templars, Blood Angels, Dark Angels, Deathwatch or Space Wolves keywords, add 1 to the Wound roll as well.",
      "type": "Faction",
      "parameter": null
    },
    {
      "name": "Signum",
      "description": "Each time this unit Remains Stationary, until the start of your next Movement phase, ranged weapons equipped by models in this unit have the [IGNORES COVER] ability.",
      "type": "Datasheet",
      "parameter": null
    },
    {
      "name": "Armorium Cherub",
      "description": "Once per battle, after making a Hit roll for a model in this unit, you can change that roll to an unmodified 6.",
      "type": "Datasheet",
      "parameter": null
    },
    {
      "name": "Designer’s Note",
      "description": "Place an Armorium Cherub token next to the unit, removing it once this ability has been used.",
      "type": "Datasheet",
      "parameter": null
    }
  ],
