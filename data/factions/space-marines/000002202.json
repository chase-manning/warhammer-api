  "options": [
    {
      "datasheetId": "000002202",
      "line": 1,
      "button": "•",
      "description": "Up to 4 Devastator Marines can each have their boltgun replaced with one of the following:\n\n• 1 grav-cannon\n• 1 heavy bolter\n• 1 lascannon\n• 1 missile launcher\n• 1 multi-melta\n• 1 plasma cannon"
    },
    {
      "datasheetId": "000002202",
      "line": 2,
      "button": "•",
      "description": "The Devastator Sergeant’s bolt pistol and boltgun can be replaced with two different weapons from the following list:*\n\n• 1 Astartes chain sword\n• 1 bolt pistol\n• 1 boltgun\n• 1 combi-weapon\n• 1 grav-pistol\n• 1 plasma pistol\n• 1 power fist\n• 1 power weapon\n• 1 thunder hammer"
    },
    {
      "datasheetId": "000002202",
      "line": 3,
      "button": "*",
      "description": "* This model can only be equipped with two ranged weapons if one of them is a Pistol (and it can only have one Pistol)"
    }
  ],
