  "abilities": [
    {
      "name": "Oath of Moment",
      "description": "If your Army Faction is ADEPTUS ASTARTES, at the start of your Command phase, select one unit from your opponent’s army. Until the start of your next Command phase, that enemy unit is your Oath of Moment target. Each time a model with this ability makes an attack that targets your Oath of Moment target:\n\n• You can re-roll the Hit roll.\n• If you are using a Codex: Space Marines Detachment and your army does not include one or more units with the Black Templars, Blood Angels, Dark Angels, Deathwatch or Space Wolves keywords, add 1 to the Wound roll as well.",
      "type": "Faction",
      "parameter": null
    },
    {
      "name": "Fire Discipline",
      "description": "Each time this unit Remains Stationary, if it includes a Long Fang Pack Leader, you can select one enemy unit that is visible to that model. Until the end of the turn, each time a model in this unit makes a ranged attack that targets that enemy unit, re-roll a Hit roll of 1.",
      "type": "Datasheet",
      "parameter": null
    },
    {
      "name": "Armorium Cherub",
      "description": "Once per battle, after making a Hit roll for a model in this unit, you can change that roll to an unmodified 6.\n\nDesigner’s Note: Place an Armorium Cherub token next to the unit, removing it once this ability has been used.",
      "type": "Datasheet",
      "parameter": null
    },
    {
      "name": "ATTACHED UNIT",
      "description": "If a Character unit from your army with the Leader ability can be attached to a Devastator Squad, it can instead be attached to this unit.",
      "type": "Special (правая колонка)",
      "parameter": null
    }
  ],
