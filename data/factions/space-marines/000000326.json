    {
      "datasheetId": "000000326",
      "line": 1,
      "button": "•",
      "description": "Any number of Long Fangs can each have their boltgun replaced with one of the following:\n• 1 grav-cannon\n• 1 heavy bolter\n• 1 heavy flamer\n• 1 lascannon\n• 1 missile launcher\n• 1 multi-melta\n• 1 plasma cannon"
    },
    {
      "datasheetId": "000000326",
      "line": 2,
      "button": "•",
      "description": "The Long Fang Pack Leader’s boltgun can be replace with one of the following\n• 1 flamer\n• 1 grav-gun\n• 1 meltagun\n• 1 plasma gun\n• 1 plasma pistol"
    },
    {
      "datasheetId": "000000326",
      "line": 3,
      "button": "•",
      "description": "The Long Fang Pack Leader’s close combat weapon can be replaced with one of the following:\n• 1 Astartes chainsword\n• 1 power fist\n• 1 power weapon"
    }
  ],
