  "abilities": [
    {
      "name": "Oath of Moment",
      "description": "If your Army Faction is ADEPTUS ASTARTES, at the start of your Command phase, select one unit from your opponent’s army. Until the start of your next Command phase, that enemy unit is your Oath of Moment target. Each time a model with this ability makes an attack that targets your Oath of Moment target:\n\n• You can re-roll the Hit roll.\n• If you are using a Codex: Space Marines Detachment and your army does not include one or more units with the Black Templars, Blood Angels, Dark Angels, Deathwatch or Space Wolves keywords, add 1 to the Wound roll as well.",
      "type": "Faction",
      "parameter": null
    },
    {
      "name": "Astartes Shield",
      "description": "The bearer has a 4+ invulnerable save.",
      "type": "Wargear",
      "parameter": null
    },
    {
      "name": "Narthecium",
      "description": "While this unit contains an APOTHECARY, in your Command phase, you can return 1 destroyed model (excluding CHARACTER models) to this unit.",
      "type": "Datasheet",
      "parameter": null
    },
    {
      "name": "Astartes Banner",
      "description": "While this unit contains a Company Ancient, add 1 to the Objective Control characteristic of models in this unit.",
      "type": "Datasheet",
      "parameter": null
    },
    {
      "name": "Honour or Death",
      "description": "While this unit contains a Company Champion, add 1 to Advance and Charge rolls made for this unit and you can target this unit with the Heroic Intervention Stratagem for 0CP, even if you have already used that Stratagem on a different unit this phase.",
      "type": "Datasheet",
      "parameter": null
    },
    {
      "name": "ATTACHED UNITS",
      "description": "If a Character unit from your army with the Leader ability can be attached to a Company Heroes unit, it can also be attached to this unit.",
      "type": "Special (правая колонка)",
      "parameter": null
    }
  ],
