  "options": [
    {
      "datasheetId": "000004154",
      "line": 1,
      "button": "•",
      "description": "The Sword Brother’s bolt pistol and boltgun can be replaced with 1 twin lightning claws or two different weapons from the following list*:\n\n• 1 Astartes chainsword\n• 1 bolt pistol\n• 1 boltgun\n• 1 combi-weapon\n• 1 grav-pistol\n• 1 hand flamer\n• 1 inferno pistol\n• 1 plasma pistol\n• 1 power fist\n• 1 power weapon\n• 1 storm bolter\n• 1 thunder hammer"
    },
    {
      "datasheetId": "000004154",
      "line": 2,
      "button": "•",
      "description": "Any number of Neophytes can each have their boltgun replaced with one of the following: \n\n• 1 Astartes shotgun\n• 1 combat knife"
    },
    {
      "datasheetId": "000004154",
      "line": 3,
      "button": "•",
      "description": "Any number of Initiates can each have their boltgun replaced with 1 Astartes chainsword."
    },
    {
      "datasheetId": "000004154",
      "line": 4,
      "button": "•",
      "description": "1 Initiate’s boltgun can be replaced with one of the following:\n\n• 1 flamer\n• 1 plasma gun\n• 1 meltagun\n• 1 grav-gun"
    },
    {
      "datasheetId": "000004154",
      "line": 5,
      "button": "•",
      "description": "1 Initiate’s boltgun can be replaced with one of the following:\n\n• 1 power weapon\n• 1 power fist\n• 1 heavy bolter\n• 1 heavy flamer\n• 1 grav-cannon\n• 1 lascannon\n• 1 missile launcher\n• 1 multi-melta\n• 1 plasma cannon"
    },
    {
      "datasheetId": "000004154",
      "line": 6,
      "button": "*",
      "description": "*This model can only be equipped with two ranged weapons if one of them is a Pistol (and it can only have one Pistol)."
    }
  ],
