  "options": [
    {
      "datasheetId": "000003976",
      "line": 1,
      "button": "•",
      "description": "Up to 4 Kasrkin Troopers can each have their hot-shot lasgun replaced with one of the following:*\n• 1 flamer\n• 1 grenade launcher\n• 1 hot-shot volley gun\n• 1 meltagun\n• 1 plasma gun"
    },
    {
      "datasheetId": "000003976",
      "line": 2,
      "button": "•",
      "description": "1 Kasrkin Trooper’s hot-shot lasgun can be replaced with 1 hot-shot marksman rifle."
    },
    {
      "datasheetId": "000003976",
      "line": 3,
      "button": "•",
      "description": "1 Kasrkin Trooper’s hot-shot lasgun can be replaced with 1 hot-shot laspistol and 1 melta mine."
    },
    {
      "datasheetId": "000003976",
      "line": 4,
      "button": "•",
      "description": "1 Kasrkin Trooper equipped with a hot-shot lasgun can be equipped with 1 vox-caster (that model’s hot-shot lasgun cannot be replaced)."
    },
    {
      "datasheetId": "000003976",
      "line": 5,
      "button": "•",
      "description": "The Kasrkin Sergeant’s chainsword can be replaced with 1 power weapon."
    },
    {
      "datasheetId": "000003976",
      "line": 6,
      "button": "•",
      "description": "The Kasrkin Sergeant’s hot-shot laspistol can be replaced with one of the following:\n• 1 bolt pistol\n• 1 plasma pistol."
    },
    {
      "datasheetId": "000003976",
      "line": 7,
      "button": "*",
      "description": "* You cannot select the same weapon from this list more than twice per unit."
    }
  ],
